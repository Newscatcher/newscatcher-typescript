{
    "name": "newscatcher-sdk",
    "version": "2.0.0",
    "private": false,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Newscatcher/newscatcher-typescript.git"
    },
    "license": "MIT",
    "type": "commonjs",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.mjs",
    "types": "./dist/cjs/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/esm/index.d.mts",
                "default": "./dist/esm/index.mjs"
            },
            "require": {
                "types": "./dist/cjs/index.d.ts",
                "default": "./dist/cjs/index.js"
            },
            "default": "./dist/cjs/index.js"
        },
        "./search": {
            "import": {
                "types": "./dist/esm/api/resources/search/exports.d.mts",
                "default": "./dist/esm/api/resources/search/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/search/exports.d.ts",
                "default": "./dist/cjs/api/resources/search/exports.js"
            },
            "default": "./dist/cjs/api/resources/search/exports.js"
        },
        "./latestHeadlines": {
            "import": {
                "types": "./dist/esm/api/resources/latestHeadlines/exports.d.mts",
                "default": "./dist/esm/api/resources/latestHeadlines/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/latestHeadlines/exports.d.ts",
                "default": "./dist/cjs/api/resources/latestHeadlines/exports.js"
            },
            "default": "./dist/cjs/api/resources/latestHeadlines/exports.js"
        },
        "./breakingNews": {
            "import": {
                "types": "./dist/esm/api/resources/breakingNews/exports.d.mts",
                "default": "./dist/esm/api/resources/breakingNews/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/breakingNews/exports.d.ts",
                "default": "./dist/cjs/api/resources/breakingNews/exports.js"
            },
            "default": "./dist/cjs/api/resources/breakingNews/exports.js"
        },
        "./authors": {
            "import": {
                "types": "./dist/esm/api/resources/authors/exports.d.mts",
                "default": "./dist/esm/api/resources/authors/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/authors/exports.d.ts",
                "default": "./dist/cjs/api/resources/authors/exports.js"
            },
            "default": "./dist/cjs/api/resources/authors/exports.js"
        },
        "./searchByLink": {
            "import": {
                "types": "./dist/esm/api/resources/searchByLink/exports.d.mts",
                "default": "./dist/esm/api/resources/searchByLink/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/searchByLink/exports.d.ts",
                "default": "./dist/cjs/api/resources/searchByLink/exports.js"
            },
            "default": "./dist/cjs/api/resources/searchByLink/exports.js"
        },
        "./sources": {
            "import": {
                "types": "./dist/esm/api/resources/sources/exports.d.mts",
                "default": "./dist/esm/api/resources/sources/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/sources/exports.d.ts",
                "default": "./dist/cjs/api/resources/sources/exports.js"
            },
            "default": "./dist/cjs/api/resources/sources/exports.js"
        },
        "./aggregation": {
            "import": {
                "types": "./dist/esm/api/resources/aggregation/exports.d.mts",
                "default": "./dist/esm/api/resources/aggregation/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/aggregation/exports.d.ts",
                "default": "./dist/cjs/api/resources/aggregation/exports.js"
            },
            "default": "./dist/cjs/api/resources/aggregation/exports.js"
        },
        "./subscription": {
            "import": {
                "types": "./dist/esm/api/resources/subscription/exports.d.mts",
                "default": "./dist/esm/api/resources/subscription/exports.mjs"
            },
            "require": {
                "types": "./dist/cjs/api/resources/subscription/exports.d.ts",
                "default": "./dist/cjs/api/resources/subscription/exports.js"
            },
            "default": "./dist/cjs/api/resources/subscription/exports.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "reference.md",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "format": "biome format --write --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "format:check": "biome format --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint": "biome lint --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "lint:fix": "biome lint --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check": "biome check --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "check:fix": "biome check --fix --unsafe --skip-parse-errors --no-errors-on-unmatched --max-diagnostics=none",
        "build": "pnpm build:cjs && pnpm build:esm",
        "build:cjs": "tsc --project ./tsconfig.cjs.json",
        "build:esm": "tsc --project ./tsconfig.esm.json && node scripts/rename-to-esm-files.js dist/esm",
        "test": "vitest",
        "test:unit": "vitest --project unit",
        "test:wire": "vitest --project wire"
    },
    "dependencies": {},
    "devDependencies": {
        "webpack": "^5.97.1",
        "ts-loader": "^9.5.1",
        "vitest": "^3.2.4",
        "msw": "2.11.2",
        "@types/node": "^18.19.70",
        "typescript": "~5.7.2",
        "@biomejs/biome": "2.4.3"
    },
    "browser": {
        "fs": false,
        "os": false,
        "path": false,
        "stream": false,
        "crypto": false
    },
    "packageManager": "pnpm@10.20.0",
    "engines": {
        "node": ">=18.0.0"
    },
    "sideEffects": false
}
